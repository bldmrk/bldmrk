{
  "name": "bldmrk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "echo 'Use: pnpm --filter @bldmrk/cli exec bldmrk dev'",
    "build:admin": "pnpm --filter @bldmrk/admin build",
    "build:theme": "pnpm --filter @bldmrk/theme-default build",
    "test:unit": "vitest run --config vitest.config.ts --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "docs:dev": "pnpm --filter @bldmrk/docs dev"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "vue-eslint-parser": "^9.0.0"
  }
}
