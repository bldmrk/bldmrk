---
import Default from './Default.astro'
import BlogCard from '../components/BlogCard.astro'

interface Child {
  slug: string
  data: {
    title: string
    date?: Date
    description?: string
  }
}

interface Props {
  title: string
  description?: string
  children: Child[]
}
const { title, description, children } = Astro.props
---

<Default title={title} description={description}>
  <h1 class="text-4xl font-bold text-gray-900 mb-8">{title}</h1>
  <slot />
  {children.length > 0 && (
    <div class="grid gap-6 mt-10 sm:grid-cols-2">
      {children.map(child => (
        <BlogCard
          title={child.data.title}
          date={child.data.date}
          description={child.data.description}
          slug={child.slug}
        />
      ))}
    </div>
  )}
</Default>
