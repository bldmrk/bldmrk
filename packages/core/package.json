    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.2",
    "@types/node-cron": "^3.0.11",
    "@types/sharp": "^0.32.0",
    "@types/unzipper": "^0.10.10",
    "@types/nodemailer": "^6.4.17",
    "memfs": "^4.57.2",
    "pino-pretty": "^13.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bldmrk/bldmrk"
