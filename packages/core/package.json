  "scripts": {
    "build": "tsc && cp -r src/blueprints dist/blueprints && cp -r src/starter dist/starter",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@mdx-js/mdx": "^3.1.1",
    "archiver": "^7.0.1",
    "argon2": "^0.44.0",
    "basic-ftp": "^5.0.5",
    "chokidar": "^5.0.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.6.1",
    "flexsearch": "^0.8.212",
    "gray-matter": "^4.0.3",
    "jose": "^6.2.3",
    "js-yaml": "^4.1.1",
    "nodemailer": "^6.9.16",
    "node-cron": "^4.2.1",
    "remark-gfm": "^4.0.1",
